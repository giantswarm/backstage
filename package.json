{
  "name": "root",
  "version": "0.138.0",
  "private": true,
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "start": "yarn env-cmd yarn backstage-cli repo start",
    "build:backend": "yarn workspace backend build",
    "build:backend-headless-service": "yarn workspace backend-headless-service build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "new": "backstage-cli new",
    "postinstall": "yarn patch-package",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@backstage/cli-defaults": "backstage:^",
    "@backstage/e2e-test-utils": "backstage:^",
    "@changesets/cli": "^2.27.8",
    "@jest/environment-jsdom-abstract": "^30.0.0",
    "@playwright/test": "^1.32.3",
    "@types/jest": "^30.0.0",
    "concurrently": "^10.0.0",
    "env-cmd": "^11.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.0",
    "node-gyp": "^11.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.0"
  },
  "resolutions": {
    "@types/express": "^5",
    "@types/express-serve-static-core": "^5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "isolated-vm": "^7.0.0",
    "knex": "^3.2.9",
    "ssh2": "^1.17.0",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.3",
    "@codemirror/language": "6.12.3",
    "@codemirror/lint": "6.9.6",
    "@codemirror/state": "6.6.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.43.0",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3",
    "codemirror-json-schema": "0.8.1",
    "@assistant-ui/tap": "^0.9.2",
    "ai": "6.0.198",
    "vm2": "3.11.5",
    "sha.js": "2.4.12",
    "basic-ftp": "5.2.0",
    "jsonpath-plus": "10.3.0",
    "protobufjs": "7.5.5",
    "axios@npm:^1.0.0": "1.8.2",
    "fast-xml-parser@npm:4.4.1": "4.5.4",
    "fast-xml-parser@npm:^4.4.1": "4.5.4",
    "fast-xml-parser@npm:^4.5.0": "4.5.4",
    "form-data@npm:~2.3.2": "2.5.4",
    "form-data@npm:^2.5.0": "2.5.4",
    "path-to-regexp@npm:~0.1.12": "0.1.13",
    "tar@npm:^6.1.11": "7.5.3",
    "tar@npm:^6.1.12": "7.5.3",
    "undici@npm:^5.28.2": "6.21.2",
    "minimatch@npm:^10.0.0": "10.0.3"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0"
  },
  "packageManager": "yarn@4.16.0"
}
