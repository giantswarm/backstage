{
  "name": "root",
  "version": "0.138.0",
  "private": true,
  "engines": {
    "node": "22 || 24"
  },
  "scripts": {
    "start": "yarn env-cmd yarn backstage-cli repo start",
    "build:backend": "yarn workspace backend build",
    "build:backend-headless-service": "yarn workspace backend-headless-service build",
    "build:all": "backstage-cli repo build --all",
    "build-image": "yarn workspace backend build-image",
    "tsc": "tsc",
    "tsc:full": "tsc --skipLibCheck false --incremental false",
    "clean": "backstage-cli repo clean",
    "test": "backstage-cli repo test --watchAll=false",
    "test:watch": "backstage-cli repo test",
    "test:all": "backstage-cli repo test --coverage --maxWorkers=50% --workerIdleMemoryLimit=1536MB",
    "test:e2e": "playwright test",
    "fix": "backstage-cli repo fix",
    "lint": "backstage-cli repo lint --since origin/main",
    "lint:all": "backstage-cli repo lint",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "ci:lint": "yarn run lint:all && yarn run prettier:check",
    "ci:verify": "concurrently --names tsc,lint,test -c blue,magenta,green \"NODE_OPTIONS='--max-old-space-size=6144' yarn run tsc --noEmit\" \"yarn run ci:lint\" \"yarn run test:all\"",
    "ci:build": "touch github-app-credentials.yaml && NODE_ENV=production yarn run build:backend --config ../../app-config.yaml --config ../../app-config.production.yaml && NODE_ENV=production yarn run build:backend-headless-service --config ../../app-config.yaml --config ../../app-config.production.yaml",
    "new": "backstage-cli new",
    "postinstall": "yarn patch-package",
    "prepare": "husky"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "plugins/*"
    ]
  },
  "devDependencies": {
    "@backstage/cli": "backstage:^",
    "@backstage/cli-defaults": "backstage:^",
    "@backstage/e2e-test-utils": "backstage:^",
    "@changesets/cli": "^2.27.8",
    "@jest/environment-jsdom-abstract": "^30.0.0",
    "@playwright/test": "^1.32.3",
    "@types/jest": "^30.0.0",
    "concurrently": "^10.0.0",
    "env-cmd": "^11.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jsdom": "^27.1.0",
    "lint-staged": "^17.0.0",
    "node-gyp": "^13.0.0",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.0"
  },
  "resolutions": {
    "@types/express": "^5",
    "@types/express-serve-static-core": "^5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "isolated-vm": "^7.0.0",
    "knex": "^3.2.9",
    "ssh2": "^1.17.0",
    "@codemirror/autocomplete": "6.20.3",
    "@codemirror/commands": "6.10.4",
    "@codemirror/language": "6.12.4",
    "@codemirror/lint": "6.9.7",
    "@codemirror/state": "6.7.0",
    "@codemirror/theme-one-dark": "6.1.3",
    "@codemirror/view": "6.43.3",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3",
    "codemirror-json-schema": "0.8.1",
    "@assistant-ui/tap": "^0.9.2",
    "@assistant-ui/core": "0.2.20",
    "assistant-stream": "0.3.25",
    "ai": "6.0.213",
    "vm2": "3.11.5",
    "sha.js": "2.4.12",
    "basic-ftp": "6.0.1",
    "jsonpath-plus": "10.4.0",
    "protobufjs": "8.6.5",
    "@protobufjs/inquire": "1.1.2",
    "tar": "7.5.16",
    "multer": "2.2.0",
    "node-forge": "1.4.0",
    "ws": "8.21.0",
    "fast-xml-builder@npm:^1.0.0": "1.1.7",
    "fast-xml-builder@npm:^1.1.4": "1.1.7",
    "fast-xml-parser@npm:4.4.1": "4.5.4",
    "fast-xml-parser@npm:^4.4.1": "4.5.4",
    "fast-xml-parser@npm:^4.5.0": "4.5.4",
    "path-to-regexp@npm:~0.1.12": "0.1.13",
    "axios@npm:^0.21.1": "0.32.0",
    "axios@npm:^1.0.0": "1.16.0",
    "axios@npm:^1.12.2": "1.16.0",
    "form-data@npm:~2.3.2": "2.5.6",
    "form-data@npm:^2.5.0": "2.5.6",
    "form-data@npm:^4.0.0": "4.0.6",
    "form-data@npm:^4.0.4": "4.0.6",
    "form-data@npm:^4.0.5": "4.0.6",
    "undici@npm:^5.28.2": "6.27.0",
    "undici@npm:7.24.7": "7.28.0",
    "undici@npm:^7.16.0": "7.28.0",
    "undici@npm:^7.2.3": "7.28.0",
    "undici@npm:^7.24.5": "7.28.0",
    "minimatch@npm:3.1.2": "3.1.4",
    "minimatch@npm:^3.0.4": "3.1.4",
    "minimatch@npm:^3.0.5": "3.1.4",
    "minimatch@npm:^3.1.1": "3.1.4",
    "minimatch@npm:^3.1.2": "3.1.4",
    "minimatch@npm:^5.0.1": "5.1.8",
    "minimatch@npm:^5.1.0": "5.1.8",
    "minimatch@npm:^7.4.3": "7.4.8",
    "minimatch@npm:^9.0.0": "9.0.7",
    "minimatch@npm:^9.0.4": "9.0.7",
    "minimatch@npm:^9.0.5": "9.0.7",
    "minimatch@npm:^10.0.0": "10.2.3",
    "minimatch@npm:^10.2.2": "10.2.3",
    "buffer-equal-constant-time@npm:1.0.1": "patch:buffer-equal-constant-time@npm%3A1.0.1#~/.yarn/patches/buffer-equal-constant-time-npm-1.0.1-41826f3419.patch"
  },
  "prettier": "@backstage/cli/config/prettier",
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0"
  },
  "packageManager": "yarn@4.17.0"
}
