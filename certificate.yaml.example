# Example file showing the expected structure of a TLS certificate value.
# The PEM markers are deliberately omitted from this placeholder so that
# pre-commit's `detect-private-key` hook does not flag this file.
certificate:
  key: |
    <PEM-encoded private key here>
    # ... (replace with the contents of your unencrypted PEM key file)
  cert: |
    <PEM-encoded certificate chain here>
    # ... (replace with the contents of your fullchain.pem file)
