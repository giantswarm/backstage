# macOS
.DS_Store

# Code editors
.vscode/*

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Coverage directory generated when running tests with coverage
coverage

# Dependencies
node_modules/

# Yarn files
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
# Offline mirror for the @giantswarm/pro git dependency: giantswarm/pro is a
# private repo, and neither CircleCI's repo-scoped checkout key nor the Docker
# image build can clone it. Committing the resolved archive lets
# `yarn install --immutable` and `yarn workspaces focus` resolve it from the
# cache without git access. Interim until @giantswarm/pro is published to npm
# (blocked on NPM_TOKEN provisioning); replace the git dependency and drop
# this exception then.
!.yarn/cache
.yarn/cache/*
!.yarn/cache/@giantswarm-pro-*

# Node version directives
.nvmrc

# dotenv environment variables file
.env
.env.*
!.env.*.example

# Build output
dist
dist-types

# Temporary change files created by Vim
*.swp

# MkDocs build output
site

# Local configuration files
*.local.yaml
*.headless-service.yaml

# Sensitive credentials
*-credentials.yaml
certificate.yaml

# vscode database functionality support files
*.session.sql

# E2E test reports
e2e-test-report/

# Cache
.cache/

/volumes

/catalog

# plugin keys
plugin-keys/*

# helm chart dependencies
charts/*/charts/
**/charts/*.tgz

# Claude Code local files
.claude/settings.local.json
.claude/user-team-info.json
.claude/tasks/
CLAUDE.local.md

# Ignore branding customization assets
/branding-assets

# graphify knowledge graph (regenerable, rebuilt by the post-commit hook)
graphify-out/
